# Normalize line endings across platforms
* text=auto eol=lf

# Windows-specific scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat these as binary so git never munges them
*.joblib binary
*.png binary
*.jpg binary
*.svs binary

# Language stats: don't count generated/data artifacts
data/** linguist-generated=true
reports/** linguist-generated=true
models/** linguist-generated=true
